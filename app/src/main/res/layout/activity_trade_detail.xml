<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del dettaglio trade.
    Qui mostriamo tutte le informazioni principali
    e permettiamo anche di eliminare il trade.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/detailAssetText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Asset"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/detailTypeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Type"
        android:textSize="18sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/detailDateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textSize="18sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/detailSessionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Session"
        android:textSize="18sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/detailResultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Result"
        android:textSize="18sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/detailSourceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Source"
        android:textSize="18sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/detailNotesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notes"
        android:textSize="18sp"
        android:paddingBottom="20dp" />

    <Button
        android:id="@+id/deleteTradeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Trade" />

</LinearLayout>