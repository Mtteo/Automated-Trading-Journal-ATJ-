<?xml version="1.0" encoding="utf-8"?>
<!--
    Schermata di inserimento manuale di un trade.
    Ora include anche selezione immagine da galleria e foto da camera.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Trade"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <EditText
            android:id="@+id/assetEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Asset (e.g. NAS100)"
            android:inputType="text" />

        <Spinner
            android:id="@+id/typeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/dateEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Date (e.g. 2026-04-14)"
            android:inputType="text" />

        <EditText
            android:id="@+id/sessionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Session (NY, London, Asia)"
            android:inputType="text" />

        <EditText
            android:id="@+id/resultInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Result (Win, Loss, BE)"
            android:inputType="text" />

        <EditText
            android:id="@+id/notesInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Notes"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <!-- Pulsanti media -->
        <Button
            android:id="@+id/pickImageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Pick Image from Gallery" />

        <Button
            android:id="@+id/takePhotoButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Take Photo" />

        <!-- Preview immagine -->
        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <Button
            android:id="@+id/saveTradeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Save Trade" />

    </LinearLayout>
</ScrollView>