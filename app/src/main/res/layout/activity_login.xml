<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#02040A"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- SOBER MARKET ZIG-ZAG BACKGROUND -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="58dp"
            android:alpha="0.10"
            android:gravity="center"
            android:text="╱╲╱╲╱╲╱"
            android:textColor="#2563EB"
            android:textSize="72sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0.07"
            android:gravity="center"
            android:text="▁▃▂▅▆▇▅▉"
            android:textColor="#3B82F6"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="64dp"
            android:alpha="0.08"
            android:gravity="center"
            android:text="╲╱╲╱╲╱╲"
            android:textColor="#DC2626"
            android:textSize="62sp"
            android:textStyle="bold" />

        <!-- SOFT BLUE GLOW -->
        <TextView
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="90dp"
            android:layout_marginEnd="-90dp"
            android:alpha="0.06"
            android:background="#2563EB" />

        <!-- SOFT RED GLOW -->
        <TextView
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="-85dp"
            android:layout_marginBottom="90dp"
            android:alpha="0.05"
            android:background="#DC2626" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- BIG LOGO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="118dp"
                android:layout_height="118dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#CC0B1120"
                app:cardCornerRadius="34dp"
                app:cardElevation="0dp"
                app:strokeColor="#334155"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/ic_launcher" />
            </com.google.android.material.card.MaterialCardView>

            <!-- LOGIN CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#D90B1120"
                app:cardCornerRadius="34dp"
                app:cardElevation="0dp"
                app:strokeColor="#263246"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="26dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Welcome back"
                        android:textColor="#FFFFFF"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Access your trading dashboard, review your performance and continue your journal."
                        android:textColor="#94A3B8"
                        android:textSize="14sp"
                        android:lineSpacingExtra="2dp" />

                    <!-- SMALL MARKET STATUS CARD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="18dp"
                        android:background="#99111C33"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bullish journal mode"
                            android:textColor="#DBEAFE"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↗"
                            android:textColor="#60A5FA"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/usernameInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="18dp"
                        android:background="#B3101826"
                        android:hint="Username"
                        android:inputType="text"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#64748B" />

                    <EditText
                        android:id="@+id/passwordInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="#B3101826"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#64748B" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/loginButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="18dp"
                        android:text="Login"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="#2563EB"
                        app:cornerRadius="20dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="#334155" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="Need a new account?"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/registerButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="10dp"
                        android:text="Create account"
                        android:textAllCaps="false"
                        android:textColor="#E2E8F0"
                        android:textStyle="bold"
                        app:backgroundTint="#B3101826"
                        app:cornerRadius="20dp"
                        app:strokeColor="#334155"
                        app:strokeWidth="1dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </FrameLayout>

</androidx.core.widget.NestedScrollView>