<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#030509"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="80dp"
            android:layout_marginEnd="28dp"
            android:alpha="0.14"
            android:text="↗"
            android:textColor="#2563EB"
            android:textSize="130sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginTop="360dp"
            android:layout_marginStart="-8dp"
            android:alpha="0.11"
            android:text="↘"
            android:textColor="#DC2626"
            android:textSize="120sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="155dp"
            android:alpha="0.08"
            android:gravity="center"
            android:text="▁▂▃▆▅▇▆▉"
            android:textColor="#3B82F6"
            android:textSize="42sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#0B1120"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E293B"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ATJ"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Automated Trading Journal"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/toggleAddMenuButton"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="+"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="31sp"
                    android:textStyle="bold"
                    app:backgroundTint="#DC2626"
                    app:cornerRadius="27dp"
                    app:strokeColor="#FCA5A5"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/addTradeMenuContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="#101826"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#7F1D1D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create Trade"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Manual input or simulated JSON event."
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addTradeButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="Manual"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            app:backgroundTint="#DC2626"
                            app:cornerRadius="18dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/simulateTradeButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="JSON"
                            android:textAllCaps="false"
                            android:textColor="#E2E8F0"
                            android:textStyle="bold"
                            app:backgroundTint="#182235"
                            app:cornerRadius="18dp"
                            app:strokeColor="#263246"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#0B1120"
                app:cardCornerRadius="34dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E293B"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/welcomeTitleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Welcome, Trader"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/welcomeSubtitleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="3dp"
                        android:text="No trades yet. Start by adding your first trade."
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="116dp"
                        android:layout_marginTop="20dp"
                        app:cardBackgroundColor="#111C33"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#1E3A8A"
                        app:strokeWidth="1dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="18dp"
                                android:alpha="0.18"
                                android:text="↗"
                                android:textColor="#60A5FA"
                                android:textSize="92sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="18dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Trading Workspace"
                                    android:textColor="#DBEAFE"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Track execution, discipline, strategy and performance."
                                    android:textColor="#93C5FD"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:background="#172554"
                                    android:paddingStart="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingEnd="10dp"
                                    android:paddingBottom="5dp"
                                    android:text="Live Journal Mode"
                                    android:textColor="#BFDBFE"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="92dp"
                            android:layout_marginEnd="7dp"
                            android:layout_weight="1"
                            android:background="#101826"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/totalTradesValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="25sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/totalTradesLabelText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="Trades"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="92dp"
                            android:layout_marginStart="7dp"
                            android:layout_marginEnd="7dp"
                            android:layout_weight="1"
                            android:background="#101826"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/winRateValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="#22C55E"
                                android:textSize="25sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/winRateLabelText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="Win rate"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="92dp"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            android:background="#101826"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/sourceValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 | 0"
                                android:textColor="#FFFFFF"
                                android:textSize="19sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/sourceLabelText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="Sources"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Journal Hub"
                android:textColor="#FFFFFF"
                android:textSize="21sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#0B1120"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E293B"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="#172554"
                        android:gravity="center"
                        android:text="↗"
                        android:textColor="#60A5FA"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Performance Analytics"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Monthly review, calendar, session and source breakdown."
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openAnalyticsButton"
                        android:layout_width="86dp"
                        android:layout_height="44dp"
                        android:text="Open"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="#2563EB"
                        app:cornerRadius="18dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="170dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#0B1120"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E293B"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="17dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Strategy"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="8dp"
                            android:layout_weight="1"
                            android:text="Setup model, checklist and visual references."
                            android:textColor="#64748B"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/openStrategyButton"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:text="Open"
                            android:textAllCaps="false"
                            android:textColor="#E2E8F0"
                            android:textStyle="bold"
                            app:backgroundTint="#101826"
                            app:cornerRadius="18dp"
                            app:strokeColor="#263246"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="170dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#0B1120"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1E293B"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="17dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="History"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="8dp"
                            android:layout_weight="1"
                            android:text="Review open, winning, losing and break-even trades."
                            android:textColor="#64748B"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/openHistoryButton"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:text="Open"
                            android:textAllCaps="false"
                            android:textColor="#E2E8F0"
                            android:textStyle="bold"
                            app:backgroundTint="#101826"
                            app:cornerRadius="18dp"
                            app:strokeColor="#263246"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#0B1120"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E293B"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Session"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Logout only when the demo is complete."
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/logoutButton"
                        android:layout_width="100dp"
                        android:layout_height="44dp"
                        android:text="Logout"
                        android:textAllCaps="false"
                        android:textColor="#FCA5A5"
                        android:textStyle="bold"
                        app:backgroundTint="#1F1117"
                        app:cornerRadius="18dp"
                        app:strokeColor="#7F1D1D"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </FrameLayout>

</androidx.core.widget.NestedScrollView>